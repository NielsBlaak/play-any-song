{
  "name": "play-any-song",
  "version": "1.0.0",
  "description": "A Hitster-style card game powered by Spotify — guess the year before the reveal. Vite + React 19 PWA with PKCE OAuth.",
  "author": "Niels Blaak",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NielsBlaak/play-any-song.git"
  },
  "keywords": [
    "spotify",
    "hitster",
    "react",
    "vite",
    "pwa",
    "pkce",
    "card-game"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "build-tracks": "node scripts/build-bundled-tracks.mjs"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vite-plugin-pwa": "^1.3.0"
  }
}
